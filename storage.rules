rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Package images, blog images - read by anyone, write by authenticated users (admins)
    match /packages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Fallback
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
